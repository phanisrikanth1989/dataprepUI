{
  "name": "tmap-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "serve:localhost": "vite --mode localhost",
    "build:localhost": "vite build --mode localhost",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --mode localhost\" \"wait-on http://localhost:4200/rectran/ && electron .\"",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:preview": "electron ."
  },
  "dependencies": {
    "axios": "^1.13.6",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.563.0",
    "pdfmake": "^0.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "reactflow": "^11.11.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "json-server": "^1.0.0-beta.12",
    "vite": "^7.2.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.rectran.dataprepui",
    "productName": "ReCTran",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "static/rectran-ui/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
